# --- Veritas server config (all optional; the server boots and serves with NONE set) ---

# Port the API listens on.
PORT=8787

# x402 payment gate on /api/round and /api/leaderboard (ADR-0003).
#   mock - real HTTP 402 challenge + any X-PAYMENT header accepted (DEFAULT; the dashboard
#          auto-pays, so the x402 handshake is functional in the demo without a wallet)
#   off  - open, no gate
#   live - real x402-express middleware against a facilitator (needs a funded wallet/chain)
X402_MODE=mock

# Address that receives x402 payments (used by mock requirements body and live settlement).
X402_PAY_TO=0x0000000000000000000000000000000000000000

# Facilitator endpoint for X402_MODE=live (defaults to the public testnet facilitator).
X402_FACILITATOR_URL=https://x402.org/facilitator

# Worker-agent engine: which engine produces judgments.
#   simulated - deterministic latent-truth swarm (DEFAULT; matches the web demo exactly)
#   live      - honest/reference judges call real LLMs (round-robin over the keys below)
# (A per-request `engine` field on POST /api/round overrides this.)
VERITAS_ENGINE=simulated

# LLM provider keys. Set any subset; live judging round-robins across whichever are present
# (ADR-0002 heterogeneity). With none set, `live` gracefully falls back to `simulated`.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- On-chain settlement (the ChainSettler seam) ---
# How a settled Round is committed to a real EVM chain.
#   off     - no chain; keep the mock tx hashes (DEFAULT; zero-setup demo)
#   local   - viem against a local anvil; auto-deploys MockUSDC/ReputationRegistry/TaskEscrow
#             on first round and funds anvil's deterministic accounts. Just run `anvil` first.
#   testnet - viem against CHAIN_RPC_URL with DEPLOYER_PRIVATE_KEY + pre-deployed addresses below
CHAIN_MODE=off

# RPC endpoint. Defaults to a local anvil.
CHAIN_RPC_URL=http://localhost:8545

# testnet only: a FUNDED private key (deployer + Requester + operator) and the addresses of the
# three already-deployed contracts (deploy them with contracts/script/Deploy.s.sol first).
DEPLOYER_PRIVATE_KEY=
CHAIN_USDC_ADDRESS=
CHAIN_REPUTATION_ADDRESS=
CHAIN_ESCROW_ADDRESS=

# testnet only: BIP-39 mnemonic the Worker pool is derived from. The deployer tops these up with
# gas + MockUSDC per Round. MUST NOT be anvil's well-known phrase — regulated testnets (Arc) block
# those public keys as senders. A demo default is used if unset; override for a real deployment.
VERITAS_WORKER_MNEMONIC=
