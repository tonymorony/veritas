# --- Veritas server config (all optional; the server boots and serves with NONE set) ---

# Port the API listens on.
PORT=8787

# x402 payment gate on /api/round and /api/leaderboard (ADR-0003).
#   mock - real HTTP 402 challenge + any X-PAYMENT header accepted (DEFAULT; the dashboard
#          auto-pays, so the x402 handshake is functional in the demo without a wallet)
#   off  - open, no gate
#   live - real x402-express middleware against a facilitator (needs a funded wallet/chain)
X402_MODE=mock

# Address that receives x402 payments (used by mock requirements body and live settlement).
X402_PAY_TO=0x0000000000000000000000000000000000000000

# Facilitator endpoint for X402_MODE=live (defaults to the public testnet facilitator).
X402_FACILITATOR_URL=https://x402.org/facilitator

# Worker-agent engine: which engine produces judgments.
#   simulated - deterministic latent-truth swarm (DEFAULT; matches the web demo exactly)
#   live      - honest/reference judges call real LLMs (round-robin over the keys below)
# (A per-request `engine` field on POST /api/round overrides this.)
VERITAS_ENGINE=simulated

# LLM provider keys. Set any subset; live judging round-robins across whichever are present
# (ADR-0002 heterogeneity). With none set, `live` gracefully falls back to `simulated`.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
